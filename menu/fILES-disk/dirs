function killer { sleep 1; ps o pid,cmd ax|egrep -q "^\ $1"; [ $? -eq 0 ] && (kill $1;echo "time limit $2";sizer $3 $2) ;} #pid,directory, size limit
function sizer { ls -1d $2/*/ | while read i; do (du -s $i 2>/dev/null | awk "{if(\$1>$1){print \$1/1048576\"Gb \"\$2}}" | egrep ".*" && sizer $1 $i & ) & killer $! $i $1;  done; } #size limit, directory to analyze
sizer $(df |awk '{if($6=="/"){print $2/10}}')
